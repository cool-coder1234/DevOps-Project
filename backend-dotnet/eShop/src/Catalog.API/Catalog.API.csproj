# .NET 8.0 SDK use karein taake targets match hon
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Context se saari files copy karein
COPY . .

# Release build generate karein
RUN dotnet publish src/WebApp/WebApp.csproj -c Release -o /app/publish

# Final runtime bhi .NET 8.0 hona chahiye
FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
COPY --from=build /app/publish .

EXPOSE 5000
ENTRYPOINT ["dotnet", "WebApp.dll", "--urls", "http://0.0.0.0:5000"]
